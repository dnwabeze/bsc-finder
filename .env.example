# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Get a FREE Helius API key at https://helius.dev (no credit card required)
# It gives much better WebSocket reliability than the public RPC
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=6194510d-e061-473e-b269-54d1446e9a5a
RPC_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=6194510d-e061-473e-b269-54d1446e9a5a

# ─── Telegram ─────────────────────────────────────────────────────────────────
# 1. Create bot: message @BotFather on Telegram → /newbot
# 2. Get your chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Monitors ─────────────────────────────────────────────────────────────────
MONITOR_PUMPFUN=true        # Pump.fun token creations
MONITOR_TRADITIONAL=true    # Raw SPL / Token-2022 InitializeMint
MONITOR_RAYDIUM=true        # New Raydium liquidity pools
MONITOR_LAUNCHPADS=true     # Moonshot, Boop, Meteora, Believe.app, etc.
MONITOR_DISCORD=true        # Watch Discord channels for CA drops (requires DISCORD_BOT_TOKEN)
MONITOR_VESTING=true        # Watch vesting platforms for token locks (requires FILTER_EXACT_SUPPLY)

# Add any other launchpad program IDs (comma-separated)
CUSTOM_LAUNCHPAD_PROGRAMS=

# ─── Discord Monitor ──────────────────────────────────────────────────────────
# Setup:
#  1. discord.com/developers/applications → New Application → Bot → copy token
#  2. Under "Privileged Gateway Intents" enable: Message Content Intent
#  3. OAuth2 → URL Generator → scope: bot → permissions: Read Messages + Read Message History
#     Invite that URL to your server
#  4. In Discord: Settings → Advanced → Developer Mode ON
#     Right-click the announcement channel → Copy Channel ID
DISCORD_BOT_TOKEN=
# Comma-separated channel IDs to watch (right-click channel → Copy Channel ID)
DISCORD_CHANNEL_IDS=

# ─── Vesting Monitor ─────────────────────────────────────────────────────────
# Exact total supply of your target token (human units). ±1% tolerance applied.
# Fires an alert when a vesting contract is created for a token with this supply.
# Works alongside all other filters — won't suppress name/keyword alerts.
FILTER_EXACT_SUPPLY=730000000
# Add extra vesting program IDs if needed (Streamflow is built-in)
VESTING_PROGRAMS=

# ─── Social Filters ───────────────────────────────────────────────────────────
REQUIRE_SOCIALS=true

FILTER_TWITTER_KEYWORDS=
FILTER_TELEGRAM_KEYWORDS=
FILTER_WEBSITE_KEYWORDS=

# ─── Name / Ticker Filter ─────────────────────────────────────────────────────
# Alert only when name OR symbol contains these (comma-separated, case-insensitive)
# Leave empty to get ALL tokens
# Example: FILTER_NAME_KEYWORDS=pepe,trump,ai,dog,cat
FILTER_NAME_KEYWORDS=

# ─── Supply Filter ────────────────────────────────────────────────────────────
# Alert when total supply falls within this range (human units, e.g. 1000000000 = 1B)
# Either name, socials, OR supply match is enough to trigger an alert
# Leave both empty to disable supply filtering
FILTER_MIN_SUPPLY=
FILTER_MAX_SUPPLY=

# ─── Distribution Settings ────────────────────────────────────────────────────

# Stage 2: how many wallets need to hold tokens before "distribution started" alert
DISTRIBUTION_STAGE2_MIN_HOLDERS=3

# Stage 3: your target distribution pattern (sorted largest to smallest, must sum ≤ 100)
# Example: one wallet 20%, another 12%, another 10%, another 8%, another 5%:
#   DISTRIBUTION_PATTERN=20,12,10,8,5
# Leave empty to disable Stage 3
DISTRIBUTION_PATTERN=

# How many percentage points each slot can deviate from the target and still match
# Example: DISTRIBUTION_TOLERANCE=5 means target 20% accepts anything 15%–25%
DISTRIBUTION_TOLERANCE=5

# How often to poll watched tokens for distribution changes (milliseconds)
DISTRIBUTION_POLL_INTERVAL_MS=15000

# How long to keep watching a token after Stage 1 detection (milliseconds)
# Default: 6 hours = 21600000
DISTRIBUTION_WATCH_DURATION_MS=21600000

# ─── Metadata ─────────────────────────────────────────────────────────────────
METADATA_FETCH_TIMEOUT=3000

# ─── BSC / BNB Chain ──────────────────────────────────────────────────────────
# Use a reliable BSC RPC — QuickNode or Ankr recommended over public endpoints
BSC_RPC_ENDPOINT=https://bsc-dataseed1.binance.org
BSC_WS_ENDPOINT=wss://bsc-ws-node.nariox.org

# Enable PancakeSwap V2 new pair monitor
MONITOR_BSC_PANCAKESWAP=false

# ─── BSC Filters ─────────────────────────────────────────────────────────────
# All 4 must pass for an alert to fire. Leave null/empty to disable that filter.

# Total token supply range (human units, e.g. 100000000 = 100M)
FILTER_BSC_SUPPLY_MIN=100000000
FILTER_BSC_SUPPLY_MAX=1000000000

# % of total supply placed in LP at launch
FILTER_BSC_LP_PCT_MIN=50
FILTER_BSC_LP_PCT_MAX=70

# LP value in USD (actual liquidity added in dollar terms)
FILTER_BSC_LP_USD_MIN=
FILTER_BSC_LP_USD_MAX=

# Launch market cap in USD (computed from price × supply at LP creation)
FILTER_BSC_MCAP_USD_MIN=3000
FILTER_BSC_MCAP_USD_MAX=10000

# Alert if any single wallet (excluding LP) holds within this % range (optional — leave empty to disable)
FILTER_BSC_HOLDER_PCT_MIN=15
FILTER_BSC_HOLDER_PCT_MAX=30

# ─── BSC Buy Watcher ──────────────────────────────────────────────────────────
# How long to watch a matched token for buys after detection (ms, default 1 hour)
BSC_BUY_WATCH_DURATION_MS=3600000
# Minimum buy size in USD to trigger an alert (leave empty to alert on all buys)
BSC_BUY_ALERT_MIN_USD=
