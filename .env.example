# ─── Solana RPC ───────────────────────────────────────────────────────────────
# Get a FREE Helius API key at https://helius.dev (no credit card required)
# It gives much better WebSocket reliability than the public RPC
RPC_ENDPOINT=https://mainnet.helius-rpc.com/?api-key=6194510d-e061-473e-b269-54d1446e9a5a
RPC_WS_ENDPOINT=wss://mainnet.helius-rpc.com/?api-key=6194510d-e061-473e-b269-54d1446e9a5a

# ─── Telegram ─────────────────────────────────────────────────────────────────
# 1. Create bot: message @BotFather on Telegram → /newbot
# 2. Get your chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Monitors ─────────────────────────────────────────────────────────────────
MONITOR_PUMPFUN=true        # Pump.fun token creations
MONITOR_TRADITIONAL=true    # Raw SPL / Token-2022 InitializeMint
MONITOR_RAYDIUM=true        # New Raydium liquidity pools
MONITOR_LAUNCHPADS=true     # Moonshot, Boop, Meteora, Believe.app, etc.

# Add any other launchpad program IDs (comma-separated)
CUSTOM_LAUNCHPAD_PROGRAMS=

# ─── Social Filters ───────────────────────────────────────────────────────────
REQUIRE_SOCIALS=true

FILTER_TWITTER_KEYWORDS=
FILTER_TELEGRAM_KEYWORDS=
FILTER_WEBSITE_KEYWORDS=

# ─── Name / Ticker Filter ─────────────────────────────────────────────────────
# Alert only when name OR symbol contains these (comma-separated, case-insensitive)
# Leave empty to get ALL tokens
# Example: FILTER_NAME_KEYWORDS=pepe,trump,ai,dog,cat
FILTER_NAME_KEYWORDS=

# ─── Supply Filter ────────────────────────────────────────────────────────────
# Alert when total supply falls within this range (human units, e.g. 1000000000 = 1B)
# Either name, socials, OR supply match is enough to trigger an alert
# Leave both empty to disable supply filtering
FILTER_MIN_SUPPLY=
FILTER_MAX_SUPPLY=

# ─── Distribution Settings ────────────────────────────────────────────────────

# Stage 2: how many wallets need to hold tokens before "distribution started" alert
DISTRIBUTION_STAGE2_MIN_HOLDERS=3

# Stage 3: your target distribution pattern (sorted largest to smallest, must sum ≤ 100)
# Example: one wallet 20%, another 12%, another 10%, another 8%, another 5%:
#   DISTRIBUTION_PATTERN=20,12,10,8,5
# Leave empty to disable Stage 3
DISTRIBUTION_PATTERN=

# How many percentage points each slot can deviate from the target and still match
# Example: DISTRIBUTION_TOLERANCE=5 means target 20% accepts anything 15%–25%
DISTRIBUTION_TOLERANCE=5

# How often to poll watched tokens for distribution changes (milliseconds)
DISTRIBUTION_POLL_INTERVAL_MS=15000

# How long to keep watching a token after Stage 1 detection (milliseconds)
# Default: 6 hours = 21600000
DISTRIBUTION_WATCH_DURATION_MS=21600000

# ─── Metadata ─────────────────────────────────────────────────────────────────
METADATA_FETCH_TIMEOUT=3000
